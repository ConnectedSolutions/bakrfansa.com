# Copia este archivo como .env y completa los valores reales
# NUNCA subas el archivo .env al repositorio

# Base de datos PostgreSQL (Railway en producción)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/bakrfansa"

# Payload CMS — clave secreta (generar con: openssl rand -hex 32)
PAYLOAD_SECRET="CHANGE_THIS_TO_A_RANDOM_STRING_IN_PRODUCTION"

# Cloudinary — CDN de imágenes de las obras
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# Stripe — pagos de reproducciones
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# URL del sitio (http://localhost:3000 en desarrollo)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
